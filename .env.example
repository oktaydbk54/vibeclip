# Copy to .env and fill in.

# LLM brain — OpenAI (preferred). DeepSeek vars kept as fallback.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_MODEL_PRO=gpt-5.4-mini

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# STT
WHISPER_MODEL=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE=int8

# Encode — h264_videotoolbox on Apple; use libx264 on Linux servers
VIDEO_ENCODER=h264_videotoolbox

# Transactional email (signup OTP) via Resend — https://resend.com
# If RESEND_API_KEY is unset, codes print to the server console (dev only).
RESEND_API_KEY=
RESEND_FROM=VibeClip <noreply@vibeclip.dev>

# Server bind (Docker sets HOST=0.0.0.0)
HOST=127.0.0.1
PORT=8765

# Admin allowlist — comma-separated emails. A user whose signup email is listed
# here is granted the admin role (the /admin dashboard) automatically. Admin is
# NEVER set by password — the user still signs up + verifies normally.
ADMIN_EMAILS=
