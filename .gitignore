.venv/
__pycache__/
*.pyc
.env
# Any .env backup/variant (e.g. .env.bak, .env.prod, sed -i'' backups) may hold
# real secrets — never commit. The tracked template .env.example is re-included.
.env.*
!.env.example
cache/
outputs/
assets/user/
.DS_Store

# Secrets & per-instance state — must NEVER be committed.
.auth_secret
.llm_secret
*.db
*.sqlite
*.sqlite3

# Source/test media at the repo root (NOT the bundled CC0 library under assets/).
# Nested mp4s (assets/gameplay/*, chat/static/demo/*) stay tracked — they ship.
/long_test.mp4
/*.mp4
/*.mov
/*.mkv

# studio2 (React/Vite) build inputs. node_modules is never committed; the built
# bundle under chat/static/studio2/ IS committed so the Python deploy serves it
# without a Node toolchain (same as the rest of chat/static).
studio/node_modules/
studio/dist/

# Local-only ops scripts (contain server host details; never publish).
scripts/deploy_remote.sh
scripts/rotate_keys.sh
